{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yunomia",
  "version": "0.1.0",
  "identifier": "io.yunomia.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run vite:dev",
    "beforeBuildCommand": "npm run vite:build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Yunomia",
        "width": 1600,
        "height": 1000,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [],
    "category": "DeveloperTool"
  },
  "plugins": {}
}
