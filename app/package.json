{
  "name": "eunomia",
  "version": "0.1.0",
  "description": "Browser-based command centre for managing Claude Code agent sessions",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "node --import tsx src/server/index.ts",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.97",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
